ezise, vorsichtig, dokumentationsgestuetzt"}, "provenance": {"transform_pipeline_version": "0.6.0", "behavior_spec_path": "docs/support_behavior_spec.md", "prompt_template_path": "prompts/teacher/jaws_de_step_by_step.md", "source_records": [{"doc_id": "jaws_de_braille", "chunk_id": "jaws_de_braille::sec_jaws_braille_allgemein_focus__schreiben_in_kurzschrift::chunk_01", "section_id": "jaws_de_braille::sec_jaws_braille_allgemein_focus__schreiben_in_kurzschrift", "section_title": "Schreiben in Kurzschrift", "normalized_path": "data/normalized/JAWS/DE/braille/index.md", "source_spans": ["data/normalized/JAWS/DE/braille/index.md#L252-L261"]}]}}
