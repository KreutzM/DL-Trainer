{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "quality_score",
    "summary",
    "blocking_reasons",
    "strengths",
    "improvement_notes",
    "source_chunk_ids_confirmed"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "reject"
      ]
    },
    "quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "improvement_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_chunk_ids_confirmed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
