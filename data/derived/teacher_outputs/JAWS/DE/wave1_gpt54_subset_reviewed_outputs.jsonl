": null, "reference_answer": "Tabelle: Befehle zum Arbeiten in Dialogen | Beschreibung | Befehl | | --- | --- | | Standardschalter ansagen | JAWS TASTE+E | | Kurztaste des aktuellen Steuerelements ansagen | UMSCHALT+NUM 5 | | Aktuelles Fenster lesen | JAWS TASTE+B | | Fenstertyp und Text lesen | JAWS TASTE+TAB | | Wort im Kontext lesen | JAWS TASTE+C | | Ausklappliste öffnen | ALT+PFEIL RUNTER | | Ausklappliste schließen | ALT+PFEIL RAUF | | Mehrere Listenelemente markieren | STRG+UMSCHALT oder STRG+LEERTASTE | | Alle Markierungen aufheben | STRG+\\ | | Spalten 1 bis 10 der Listenansicht lesen | STRG+JAWS TASTE+1 bis 0 | Tipp: Wenn Sie auf einem Steuerelement des Dialogfensters JAWS-TASTE+F1 drücken, erhalten Sie eine kontextabhängige Hilfe.", "rubric": {"must_include": ["JAWS Befehle zum Arbeiten in Dialogen", "Tipp:"], "must_not_include": ["erfundene Produktdetails"], "style": "praezise, vorsichtig, dokumentationsgestuetzt"}, "provenance": {"transform_pipeline_version": "0.6.0", "behavior_spec_path": "docs/support_behavior_spec.md", "prompt_template_path": "prompts/teacher/jaws_de_direct_support.md", "source_records": [{"doc_id": "jaws_de_hilfe_kernfunktionen", "chunk_id": "jaws_de_hilfe_kernfunktionen::sec_schnelleinstellung_uebersicht__jaws_befehle_zum_arbeiten_in_dialogen::chunk_01", "section_id": "jaws_de_hilfe_kernfunktionen::sec_schnelleinstellung_uebersicht__jaws_befehle_zum_arbeiten_in_dialogen", "section_title": "JAWS Befehle zum Arbeiten in Dialogen", "normalized_path": "data/normalized/JAWS/DE/hilfe_kernfunktionen/index.md", "source_spans": ["data/normalized/JAWS/DE/hilfe_kernfunktionen/index.md#L2379-L2399"]}]}}, "provenance": {"transform_pipeline_version": "0.6.0", "source_job_path": "data/derived/teacher_jobs/JAWS/DE/wave1_generation_jobs.jsonl", "source_records": [{"doc_id": "jaws_de_hilfe_kernfunktionen", "chunk_id": "jaws_de_hilfe_kernfunktionen::sec_schnelleinstellung_uebersicht__jaws_befehle_zum_arbeiten_in_dialogen::chunk_01", "section_id": "ja