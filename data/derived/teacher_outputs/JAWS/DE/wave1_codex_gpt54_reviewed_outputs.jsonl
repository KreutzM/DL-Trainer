derung fuer die JAWS-Standardeinstellungen gelten soll, oder waehlen Sie andernfalls die betroffene Anwendung.\n3. Geben Sie im Sucheingabefeld \"Uebersetzung\" ein.\n4. Wechseln Sie mit PFEIL RUNTER in der Strukturansicht zum gefilterten Eintrag Uebersetzung, druecken Sie EINGABE und erweitern Sie die Gruppe bei Bedarf mit PFEIL RECHTS.\n5. Schalten Sie mit LEERTASTE in der Ausklappliste Ausgabe auf den gewuenschten Braille-Lesemodus um.", "rubric": {"must_include": ["EINFUEGEN+F2", "LEERTASTE"], "must_not_include": ["erfundene Zwischenschritte", "nicht belegte Menuepfade"], "style": "praezise, vorsichtig, dokumentationsgestuetzt"}, "provenance": {"transform_pipeline_version": "0.6.0", "behavior_spec_path": "docs/support_behavior_spec.md", "prompt_template_path": "prompts/teacher/jaws_de_step_by_step.md", "source_records": [{"doc_id": "jaws_de_braille", "chunk_id": "jaws_de_braille::sec_jaws_braille_allgemein_focus__schreiben_in_kurzschrift::chunk_01", "section_id": "jaws_de_braille::sec_jaws_braille_allgemein_focus__schreiben_in_kurzschrift", "section_title": "Schreiben in Kurzschrift", "normalized_path": "data/normalized/JAWS/DE/braille/index.md", "source_spans": ["data/normalized/JAWS/DE/braille/index.md#L252-L261"]}]}}, "provenance": {"transform_pipeline_version": "0.6.0", "source_job_path": "data/derived/teacher_jobs/JAWS/DE/wave1_generation_jobs.jsonl", "source_records": [{"doc_id": "jaws_de_braille", "chunk_id": "jaws_de_braille::sec_jaws_braille_allgemein_focus__schreiben_in_kurzschrift::chunk_01", "section_id": "jaws_de_braille::sec_jaws_braille_allgemein_focus__schreiben_in_kurzschrift", "section_title": "Schreiben in Kurzschrift", "normalized_path": "data/normalized/JAWS/DE/braille/index.md", "source_spans": ["data/normalized/JAWS/DE/braille/index.md#L252-L261"]}]}}
