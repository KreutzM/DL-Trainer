{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Retrieval Chunk",
  "type": "object",
  "required": [
    "chunk_id",
    "doc_id",
    "product",
    "language",
    "source_path",
    "normalized_path",
    "chunk_path",
    "section_id",
    "section_title",
    "section_path",
    "chunk_index",
    "chunk_count_in_doc",
    "char_count",
    "conversion_stage",
    "provenance",
    "title",
    "content",
    "source_spans",
    "review_status"
  ],
  "properties": {
    "chunk_id": {
      "type": "string"
    },
    "doc_id": {
      "type": "string"
    },
    "product": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "source_path": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    },
    "normalized_path": {
      "type": "string"
    },
    "chunk_path": {
      "type": "string"
    },
    "section_id": {
      "type": "string"
    },
    "section_title": {
      "type": "string"
    },
    "section_path": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "section_path_text": {
      "type": "string"
    },
    "heading_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "chunk_index": {
      "type": "integer",
      "minimum": 1
    },
    "chunk_index_in_section": {
      "type": "integer",
      "minimum": 1
    },
    "section_chunk_count": {
      "type": "integer",
      "minimum": 1
    },
    "chunk_count_in_doc": {
      "type": "integer",
      "minimum": 1
    },
    "char_count": {
      "type": "integer",
      "minimum": 1
    },
    "conversion_stage": {
      "type": "string"
    },
    "transform_pipeline_version": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "chunk_type": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "source_spans": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "contains_list": {
      "type": "boolean"
    },
    "contains_steps": {
      "type": "boolean"
    },
    "contains_source_marker": {
      "type": "boolean"
    },
    "review_status": {
      "type": "string"
    },
    "provenance": {
      "type": "object",
      "required": [
        "doc_id",
        "section_id",
        "source_spans",
        "transform_pipeline_version"
      ],
      "properties": {
        "doc_id": {
          "type": "string"
        },
        "section_id": {
          "type": "string"
        },
        "normalized_path": {
          "type": "string"
        },
        "raw_source_file": {
          "type": "string"
        },
        "raw_source_root": {
          "type": "string"
        },
        "raw_collection_manifest": {
          "type": "string"
        },
        "upstream_conversion_stage": {
          "type": "string"
        },
        "transform_pipeline_version": {
          "type": "string"
        },
        "source_spans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "path",
              "line_start",
              "line_end"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "line_start": {
                "type": "integer",
                "minimum": 1
              },
              "line_end": {
                "type": "integer",
                "minimum": 1
              },
              "heading_line": {
                "type": "integer",
                "minimum": 1
              },
              "section_path": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
