{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Qwen SFT Metadata",
  "type": "object",
  "required": [
    "id",
    "split",
    "record_type",
    "source_doc_ids",
    "source_chunk_ids",
    "review_status",
    "gold_source_path",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "split": {
      "type": "string",
      "enum": ["train", "eval"]
    },
    "record_type": {
      "type": "string",
      "enum": ["sft_train", "sft_eval"]
    },
    "product": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "task_type": {
      "type": ["string", "null"]
    },
    "case_type": {
      "type": ["string", "null"]
    },
    "source_doc_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "source_chunk_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "teacher_model": {
      "type": "string"
    },
    "teacher_run_id": {
      "type": "string"
    },
    "teacher_prompt_version": {
      "type": "string"
    },
    "generation_mode": {
      "type": "string"
    },
    "review_status": {
      "type": "string",
      "enum": ["draft", "seed", "teacher_generated", "human_reviewed", "promoted", "rejected"]
    },
    "approved_by": {
      "type": ["string", "null"]
    },
    "gold_source_path": {
      "type": "string",
      "minLength": 1
    },
    "promoted_from": {
      "type": ["object", "null"]
    },
    "provenance": {
      "type": "object",
      "required": ["source_records", "transform_pipeline_version"],
      "properties": {
        "transform_pipeline_version": { "type": "string" },
        "behavior_spec_path": { "type": "string" },
        "prompt_template_path": { "type": "string" },
        "source_records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["doc_id", "chunk_id", "normalized_path", "source_spans"],
            "properties": {
              "doc_id": { "type": "string" },
              "chunk_id": { "type": "string" },
              "section_id": { "type": "string" },
              "section_title": { "type": "string" },
              "normalized_path": { "type": "string" },
              "source_spans": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "expected_behavior": {
      "type": ["string", "null"]
    },
    "reference_answer": {
      "type": ["string", "null"]
    },
    "rubric": {
      "type": ["object", "null"]
    }
  },
  "additionalProperties": true
}
