{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Eval Case",
  "type": "object",
  "required": [
    "eval_id",
    "product",
    "language",
    "case_type",
    "prompt",
    "expected_behavior",
    "source_doc_ids",
    "source_chunk_ids",
    "teacher_model",
    "teacher_run_id",
    "teacher_prompt_version",
    "generation_mode",
    "review_status",
    "split",
    "provenance",
    "rubric"
  ],
  "properties": {
    "eval_id": { "type": "string" },
    "product": { "type": "string" },
    "language": { "type": "string" },
    "case_type": {
      "type": "string",
      "enum": [
        "faq_direct_answer",
        "troubleshooting",
        "step_by_step",
        "clarification",
        "uncertainty_escalation"
      ]
    },
    "prompt": { "type": "string", "minLength": 1 },
    "case_description": { "type": "string" },
    "expected_behavior": { "type": "string", "minLength": 1 },
    "source_doc_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "source_chunk_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "teacher_provider": { "type": "string", "minLength": 1 },
    "teacher_model": { "type": "string", "minLength": 1 },
    "teacher_run_id": { "type": "string", "minLength": 1 },
    "teacher_prompt_version": { "type": "string", "minLength": 1 },
    "generation_mode": { "type": "string", "minLength": 1 },
    "review_status": {
      "type": "string",
      "enum": ["draft", "seed", "teacher_generated", "codex_reviewed", "human_reviewed", "promoted", "rejected"]
    },
    "split": { "type": "string", "minLength": 1 },
    "approved_by": {
      "type": ["string", "null"]
    },
    "promoted_from": {
      "type": ["object", "null"],
      "properties": {
        "teacher_output_path": { "type": "string" },
        "output_id": { "type": "string" },
        "job_id": { "type": "string" },
        "teacher_run_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "reference_answer": { "type": "string" },
    "rubric": {
      "type": "object",
      "required": ["must_include", "must_not_include", "style"],
      "properties": {
        "must_include": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_not_include": {
          "type": "array",
          "items": { "type": "string" }
        },
        "style": { "type": "string" },
        "scoring_notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "required": ["source_records", "transform_pipeline_version"],
      "properties": {
        "transform_pipeline_version": { "type": "string" },
        "behavior_spec_path": { "type": "string" },
        "prompt_template_path": { "type": "string" },
        "source_records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["doc_id", "chunk_id", "normalized_path", "source_spans"],
            "properties": {
              "doc_id": { "type": "string" },
              "chunk_id": { "type": "string" },
              "section_id": { "type": "string" },
              "section_title": { "type": "string" },
              "normalized_path": { "type": "string" },
              "source_spans": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
