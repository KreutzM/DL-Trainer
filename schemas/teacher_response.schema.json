{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Teacher Response",
  "type": "object",
  "required": [
    "response_id",
    "job_id",
    "output_id",
    "record_type",
    "target_split",
    "product",
    "language",
    "task_type",
    "source_doc_ids",
    "source_chunk_ids",
    "teacher_provider",
    "teacher_model",
    "teacher_run_id",
    "teacher_prompt_version",
    "generation_mode",
    "response_status",
    "response_format_version",
    "raw_text",
    "parsed_response",
    "provenance"
  ],
  "properties": {
    "response_id": { "type": "string", "minLength": 1 },
    "job_id": { "type": "string", "minLength": 1 },
    "output_id": { "type": "string", "minLength": 1 },
    "wave_id": { "type": ["string", "null"] },
    "record_type": {
      "type": "string",
      "enum": ["sft_sample", "eval_case"]
    },
    "target_split": {
      "type": "string",
      "enum": ["train", "eval"]
    },
    "product": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 1 },
    "task_type": {
      "type": "string",
      "enum": [
        "faq_direct_answer",
        "troubleshooting",
        "step_by_step",
        "clarification",
        "uncertainty_escalation"
      ]
    },
    "source_doc_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "source_chunk_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "teacher_provider": { "type": "string", "minLength": 1 },
    "teacher_model": { "type": "string", "minLength": 1 },
    "teacher_run_id": { "type": "string", "minLength": 1 },
    "teacher_prompt_version": { "type": "string", "minLength": 1 },
    "generation_mode": { "type": "string", "minLength": 1 },
    "response_status": {
      "type": "string",
      "enum": ["completed", "imported"]
    },
    "response_format_version": { "type": "string", "minLength": 1 },
    "provider_response_id": {
      "type": ["string", "null"]
    },
    "raw_text": { "type": "string", "minLength": 1 },
    "usage": {
      "type": ["object", "null"]
    },
    "parsed_response": {
      "type": "object",
      "required": [
        "answer",
        "task_type",
        "needs_clarification",
        "clarification_question",
        "escalate",
        "uncertainty_reason",
        "steps",
        "source_chunk_ids",
        "notes"
      ],
      "properties": {
        "answer": { "type": "string", "minLength": 1 },
        "task_type": {
          "type": "string",
          "enum": [
            "faq_direct_answer",
            "troubleshooting",
            "step_by_step",
            "clarification",
            "uncertainty_escalation"
          ]
        },
        "needs_clarification": { "type": "boolean" },
        "clarification_question": { "type": ["string", "null"] },
        "escalate": { "type": "boolean" },
        "uncertainty_reason": { "type": ["string", "null"] },
        "steps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "case_description": { "type": "string" },
        "expected_behavior": { "type": "string" },
        "reference_answer": { "type": "string" },
        "rubric": {
          "type": "object",
          "properties": {
            "must_include": {
              "type": "array",
              "items": { "type": "string" }
            },
            "must_not_include": {
              "type": "array",
              "items": { "type": "string" }
            },
            "style": { "type": "string" },
            "scoring_notes": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "source_chunk_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_job_path",
        "behavior_spec_path",
        "prompt_template_path",
        "source_records",
        "transform_pipeline_version"
      ],
      "properties": {
        "transform_pipeline_version": { "type": "string" },
        "source_job_path": { "type": "string" },
        "behavior_spec_path": { "type": "string" },
        "prompt_template_path": { "type": "string" },
        "source_records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["doc_id", "chunk_id", "normalized_path", "source_spans"],
            "properties": {
              "doc_id": { "type": "string" },
              "chunk_id": { "type": "string" },
              "section_id": { "type": "string" },
              "section_title": { "type": "string" },
              "normalized_path": { "type": "string" },
              "source_spans": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
