{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Teacher User Simulation",
  "type": "object",
  "required": [
    "simulation_id",
    "job_id",
    "target_split",
    "expected_output_kind",
    "task_type",
    "product",
    "language",
    "source_doc_ids",
    "source_chunk_ids",
    "simulator_provider",
    "simulator_model",
    "simulator_run_id",
    "simulator_prompt_version",
    "generation_mode",
    "simulation_status",
    "request_text",
    "user_goal",
    "difficulty",
    "phrasing_style",
    "scenario_summary",
    "provenance"
  ],
  "properties": {
    "simulation_id": { "type": "string", "minLength": 1 },
    "job_id": { "type": "string", "minLength": 1 },
    "wave_id": { "type": ["string", "null"] },
    "target_split": {
      "type": "string",
      "enum": ["train", "eval"]
    },
    "expected_output_kind": {
      "type": "string",
      "enum": ["sft_sample", "eval_case"]
    },
    "task_type": {
      "type": "string",
      "enum": [
        "faq_direct_answer",
        "troubleshooting",
        "step_by_step",
        "clarification",
        "uncertainty_escalation"
      ]
    },
    "product": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 1 },
    "source_doc_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "source_chunk_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "simulator_provider": { "type": "string", "minLength": 1 },
    "simulator_model": { "type": "string", "minLength": 1 },
    "simulator_run_id": { "type": "string", "minLength": 1 },
    "simulator_prompt_version": { "type": "string", "minLength": 1 },
    "generation_mode": { "type": "string", "minLength": 1 },
    "simulation_status": {
      "type": "string",
      "enum": ["completed"]
    },
    "request_text": { "type": "string", "minLength": 1 },
    "user_goal": { "type": "string", "minLength": 1 },
    "difficulty": {
      "type": "string",
      "enum": ["basic", "intermediate", "advanced"]
    },
    "phrasing_style": {
      "type": "string",
      "enum": ["neutral", "urgent", "uncertain", "task_focused", "frustrated"]
    },
    "scenario_summary": { "type": "string", "minLength": 1 },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "codex_cli": {
      "type": ["object", "null"]
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_job_path",
        "behavior_spec_path",
        "prompt_template_path",
        "source_records",
        "transform_pipeline_version"
      ],
      "properties": {
        "transform_pipeline_version": { "type": "string" },
        "source_job_path": { "type": "string" },
        "behavior_spec_path": { "type": "string" },
        "prompt_template_path": { "type": "string" },
        "source_records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["doc_id", "chunk_id", "normalized_path", "source_spans"],
            "properties": {
              "doc_id": { "type": "string" },
              "chunk_id": { "type": "string" },
              "section_id": { "type": "string" },
              "section_title": { "type": "string" },
              "normalized_path": { "type": "string" },
              "source_spans": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
