{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Qwen SFT Record",
  "type": "object",
  "required": ["id", "messages"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
