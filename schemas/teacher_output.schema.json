{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Teacher Output",
  "type": "object",
  "required": [
    "output_id",
    "job_id",
    "record_type",
    "target_split",
    "product",
    "language",
    "task_type",
    "source_doc_ids",
    "source_chunk_ids",
    "teacher_model",
    "teacher_run_id",
    "teacher_prompt_version",
    "generation_mode",
    "review_status",
    "candidate",
    "provenance"
  ],
  "properties": {
    "output_id": { "type": "string" },
    "job_id": { "type": "string" },
    "record_type": {
      "type": "string",
      "enum": ["sft_sample", "eval_case"]
    },
    "target_split": {
      "type": "string",
      "enum": ["train", "eval"]
    },
    "product": { "type": "string" },
    "language": { "type": "string" },
    "task_type": {
      "type": "string",
      "enum": [
        "faq_direct_answer",
        "troubleshooting",
        "step_by_step",
        "clarification",
        "uncertainty_escalation"
      ]
    },
    "source_doc_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "source_chunk_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "teacher_provider": { "type": "string", "minLength": 1 },
    "teacher_model": { "type": "string" },
    "teacher_run_id": { "type": "string" },
    "teacher_prompt_version": { "type": "string" },
    "generation_mode": { "type": "string" },
    "review_status": {
      "type": "string",
      "enum": ["draft", "seed", "teacher_generated", "human_reviewed", "promoted", "rejected"]
    },
    "approved_by": {
      "type": ["string", "null"]
    },
    "promoted_to": {
      "type": ["string", "null"]
    },
    "raw_response_path": {
      "type": ["string", "null"]
    },
    "candidate": {
      "type": "object",
      "minProperties": 1
    },
    "provenance": {
      "type": "object",
      "required": ["source_job_path", "source_records", "transform_pipeline_version"],
      "properties": {
        "transform_pipeline_version": { "type": "string" },
        "source_job_path": { "type": "string" },
        "source_records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["doc_id", "chunk_id", "normalized_path", "source_spans"],
            "properties": {
              "doc_id": { "type": "string" },
              "chunk_id": { "type": "string" },
              "section_id": { "type": "string" },
              "section_title": { "type": "string" },
              "normalized_path": { "type": "string" },
              "source_spans": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
